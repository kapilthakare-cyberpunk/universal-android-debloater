# Rust build artifacts
/target
/debug
/release

# Cargo.lock (uncomment if building a library)
# Cargo.lock

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Rust analyzer
.rust-analyzer/

# Environment variables
.env
.env.local
.env.*.local

# Log files (generated at runtime)
*.log
UAD_*.log

# OS-specific config directories (created at runtime)
# macOS: ~/Library/Caches/uad/
# Linux: ~/.cache/uad/
# Windows: %LOCALAPPDATA%\uad\

# Backup files (generated at runtime)
# Stored in OS cache dir under uad/backups/

# Coverage reports
*.profraw
*.profdata
coverage/
tarpaulin-report.html
cobertura.xml
lcov.info

# Benchmark results
criterion/

# Fuzzing artifacts
fuzz/corpus/
fuzz/artifacts/

# Release artifacts (generated by packaging scripts)
dist/
bin/

# Generated icons (uncomment if you want to track them in git)
# resources/assets/icon.icns
# resources/assets/icon.ico
# resources/assets/icon.png

# Temporary packaging files
.dmg-staging/
.deb-build/
.appimage-build/
.appimage-archive/
linuxdeploy-*.AppImage
*.sparseimage
*.shadow

# Temporary files
tmp_*
*.tmp

# Documentation build
doc/
